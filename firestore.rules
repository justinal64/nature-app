rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Firestore scope is intentionally narrow — auth profile only.
    // Sightings, favorites, and journal entries are local-first (AsyncStorage).
    match /user_profiles/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Deny everything else explicitly.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
